<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Floss.App.App"
             RequestedThemeVariant="Dark">

    <Application.Styles>
        <FluentTheme />

        <!-- ══════════════════════════════════════════════════════════════════
             FLAT BUTTON — replaces the Fluent "elevated card" look with a
             dead-simple transparent container that adds a white overlay on
             hover/press.  All explicitly-set Background/Border values on
             individual buttons are preserved because the outer Border binds
             to TemplateBinding, not a hard-coded resource.
        ══════════════════════════════════════════════════════════════════ -->
        <Style Selector="Button">
            <Setter Property="Background"    Value="Transparent"/>
            <Setter Property="BorderBrush"   Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius"  Value="3"/>
            <Setter Property="Padding"       Value="6,4"/>
            <Setter Property="Cursor"        Value="Hand"/>
            <Setter Property="Foreground"    Value="#A0AAB4"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <!-- Outer Border supplies the button's own bg/border/radius.
                         ClipToBounds ensures children respect the corner radius. -->
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            ClipToBounds="True">
                        <Panel>
                            <!-- Additive hover/press overlay — does not disturb
                                 any explicit Background set on the button itself. -->
                            <Border Name="Overlay" IsHitTestVisible="False"
                                    Background="Transparent"/>
                            <ContentPresenter Padding="{TemplateBinding Padding}"
                                              HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              Foreground="{TemplateBinding Foreground}"/>
                        </Panel>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Button:pointerover /template/ Border#Overlay">
            <Setter Property="Background" Value="#18ffffff"/>
        </Style>
        <Style Selector="Button:pressed /template/ Border#Overlay">
            <Setter Property="Background" Value="#2cffffff"/>
        </Style>
        <Style Selector="Button:disabled">
            <Setter Property="Opacity" Value="0.35"/>
        </Style>

        <!-- ── ToggleButton inherits the flat button look ─────────────────── -->
        <Style Selector="ToggleButton">
            <Setter Property="Background"    Value="Transparent"/>
            <Setter Property="BorderBrush"   Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius"  Value="3"/>
            <Setter Property="Padding"       Value="6,4"/>
            <Setter Property="Cursor"        Value="Hand"/>
            <Setter Property="Foreground"    Value="#A0AAB4"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            ClipToBounds="True">
                        <Panel>
                            <Border Name="Overlay" IsHitTestVisible="False"
                                    Background="Transparent"/>
                            <ContentPresenter Padding="{TemplateBinding Padding}"
                                              HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              Foreground="{TemplateBinding Foreground}"/>
                        </Panel>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="ToggleButton:pointerover /template/ Border#Overlay">
            <Setter Property="Background" Value="#18ffffff"/>
        </Style>
        <Style Selector="ToggleButton:pressed /template/ Border#Overlay">
            <Setter Property="Background" Value="#2cffffff"/>
        </Style>

        <!-- ── TextBox — sharp corners, no Fluent glow ───────────────────── -->
        <Style Selector="TextBox">
            <Setter Property="CornerRadius"  Value="2"/>
            <Setter Property="Foreground"    Value="#d7dde8"/>
            <Setter Property="CaretBrush"    Value="#d7dde8"/>
            <Setter Property="SelectionBrush" Value="#3d6fd8"/>
            <Setter Property="SelectionForegroundBrush" Value="#ffffff"/>
        </Style>
        <!-- Kill the Fluent "focus glow" border colour -->
        <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="#3d6fd8"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="#4a5568"/>
        </Style>

        <!-- ── ComboBox — flatten ─────────────────────────────────────────── -->
        <Style Selector="ComboBox">
            <Setter Property="CornerRadius"  Value="2"/>
            <Setter Property="Foreground"    Value="#A0AAB4"/>
            <Setter Property="Background"    Value="#13151a"/>
            <Setter Property="BorderBrush"   Value="#2b303b"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"       Value="6,0"/>
        </Style>
        <Style Selector="ComboBox:pointerover">
            <Setter Property="BorderBrush" Value="#4a5568"/>
        </Style>
        <Style Selector="ComboBox:focus">
            <Setter Property="BorderBrush" Value="#3d6fd8"/>
        </Style>
        <Style Selector="ComboBoxItem">
            <Setter Property="Foreground"    Value="#A0AAB4"/>
            <Setter Property="Background"    Value="Transparent"/>
            <Setter Property="Padding"       Value="8,5"/>
            <Setter Property="FontSize"      Value="11"/>
        </Style>
        <Style Selector="ComboBoxItem:selected">
            <Setter Property="Background" Value="#22355f"/>
            <Setter Property="Foreground" Value="#d7dde8"/>
        </Style>
        <Style Selector="ComboBoxItem:pointerover">
            <Setter Property="Background" Value="#1a1c22"/>
        </Style>

        <!-- ── Menu / MenuItem ────────────────────────────────────────────── -->
        <Style Selector="Menu">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#A0AAB4"/>
        </Style>
        <Style Selector="MenuItem">
            <Setter Property="Foreground" Value="#A0AAB4"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding"    Value="10,6"/>
            <Setter Property="FontSize"   Value="12"/>
        </Style>
        <Style Selector="MenuItem:selected">
            <Setter Property="Background" Value="#1a1c22"/>
        </Style>
        <Style Selector="MenuItem:pointerover">
            <Setter Property="Background" Value="#1a1c22"/>
        </Style>

        <!-- ── Horizontal slider — chunky progress-bar style ───────────────── -->
        <Style Selector="Slider:horizontal">
            <Setter Property="Background" Value="#161820"/>
            <Setter Property="MinHeight" Value="22"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Grid MinHeight="24" VerticalAlignment="Center">
                        <!-- track trough — binds to the control's Background so colour
                             sliders can set their own gradients, regular sliders get
                             the default trough colour via the style below. -->
                        <Border VerticalAlignment="Center" Height="10" CornerRadius="5"
                                Background="{TemplateBinding Background}"
                                IsHitTestVisible="False"/>
                        <Track Name="PART_Track" Orientation="Horizontal"
                               Minimum="{TemplateBinding Minimum}"
                               Maximum="{TemplateBinding Maximum}"
                               Value="{TemplateBinding Value, Mode=TwoWay}">
                            <Track.DecreaseButton>
                                <RepeatButton Name="PART_DecreaseButton" Focusable="False" Cursor="Hand">
                                    <RepeatButton.Template>
                                        <ControlTemplate>
                                            <Border Name="Fill" Height="10" VerticalAlignment="Center"
                                                    CornerRadius="5,0,0,5" Background="#3a6fd8"/>
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.DecreaseButton>
                            <Track.Thumb>
                                <Thumb Cursor="Hand" Width="16" Height="16">
                                    <Thumb.Template>
                                        <ControlTemplate>
                                            <Grid Width="16" Height="16">
                                                <Ellipse Width="14" Height="14"
                                                         Fill="#6a94ec"
                                                         Stroke="#13151a"
                                                         StrokeThickness="2"/>
                                            </Grid>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                            <Track.IncreaseButton>
                                <RepeatButton Name="PART_IncreaseButton" Focusable="False" Cursor="Hand">
                                    <RepeatButton.Template>
                                        <ControlTemplate>

                                            <Border Height="10" VerticalAlignment="Center"
                                                    Background="Transparent"/>
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.IncreaseButton>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Slider:horizontal:pointerover /template/ RepeatButton#PART_DecreaseButton /template/ Border#Fill">
            <Setter Property="Background" Value="#4d82ec"/>
        </Style>
        <Style Selector="Slider:horizontal:pressed /template/ RepeatButton#PART_DecreaseButton /template/ Border#Fill">
            <Setter Property="Background" Value="#5a90f5"/>
        </Style>
        <Style Selector="Slider:horizontal:pointerover /template/ Thumb /template/ Ellipse">
            <Setter Property="Fill" Value="#90b4f8"/>
        </Style>
        <Style Selector="Slider:horizontal:pressed /template/ Thumb /template/ Ellipse">
            <Setter Property="Fill" Value="#a8c4fa"/>
        </Style>

        <!-- ── ScrollBar: keep it minimal ────────────────────────────────── -->
        <Style Selector="ScrollBar">
            <Setter Property="Opacity" Value="0.4"/>
        </Style>

        <!-- ── ListBox / ListBoxItem ──────────────────────────────────────── -->
        <Style Selector="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding"    Value="0"/>
        </Style>
        <Style Selector="ListBoxItem:selected">
            <Setter Property="Background" Value="Transparent"/>
        </Style>

    </Application.Styles>
</Application>
