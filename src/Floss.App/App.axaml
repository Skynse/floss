<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Floss.App.App"
             RequestedThemeVariant="Dark">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="/Styles/Theme.axaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />

        <Style Selector="Window">
            <Setter Property="FontFamily" Value="Inter, Segoe UI, Noto Sans, Ubuntu, Cantarell, Arial"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Background" Value="{StaticResource Bg0}"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
        </Style>

        <Style Selector="Button">
            <Setter Property="Background"    Value="Transparent"/>
            <Setter Property="BorderBrush"   Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius"  Value="2"/>
            <Setter Property="Padding"       Value="7,3"/>
            <Setter Property="Cursor"        Value="Hand"/>
            <Setter Property="Foreground"    Value="{StaticResource TextSecondary}"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            ClipToBounds="True">
                        <Panel>
                            <Border Name="Overlay" IsHitTestVisible="False"
                                    Background="Transparent"
                                    CornerRadius="{TemplateBinding CornerRadius}"/>
                            <ContentPresenter Padding="{TemplateBinding Padding}"
                                              HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              Foreground="{TemplateBinding Foreground}"/>
                        </Panel>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Button:pointerover /template/ Border#Overlay">
            <Setter Property="Background" Value="#14ffffff"/>
        </Style>
        <Style Selector="Button:pressed /template/ Border#Overlay">
            <Setter Property="Background" Value="#24ffffff"/>
        </Style>
        <Style Selector="Button:disabled">
            <Setter Property="Opacity" Value="0.35"/>
        </Style>

        <!-- ── ToggleButton ───────────────────────────────────────────────── -->
        <Style Selector="ToggleButton">
            <Setter Property="Background"    Value="Transparent"/>
            <Setter Property="BorderBrush"   Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius"  Value="2"/>
            <Setter Property="Padding"       Value="7,3"/>
            <Setter Property="Cursor"        Value="Hand"/>
            <Setter Property="Foreground"    Value="{StaticResource TextSecondary}"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            ClipToBounds="True">
                        <Panel>
                            <Border Name="Overlay" IsHitTestVisible="False"
                                    Background="Transparent"
                                    CornerRadius="{TemplateBinding CornerRadius}"/>
                            <ContentPresenter Padding="{TemplateBinding Padding}"
                                              HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              Foreground="{TemplateBinding Foreground}"/>
                        </Panel>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="ToggleButton:pointerover /template/ Border#Overlay">
            <Setter Property="Background" Value="#14ffffff"/>
        </Style>
        <Style Selector="ToggleButton:pressed /template/ Border#Overlay">
            <Setter Property="Background" Value="#24ffffff"/>
        </Style>

        <Style Selector="TextBox">
            <Setter Property="CornerRadius"     Value="2"/>
            <Setter Property="Foreground"       Value="{StaticResource TextPrimary}"/>
            <Setter Property="CaretBrush"       Value="{StaticResource TextPrimary}"/>
            <Setter Property="SelectionBrush"    Value="{StaticResource Accent}"/>
            <Setter Property="SelectionForegroundBrush" Value="#ffffff"/>
            <Setter Property="BorderBrush"       Value="{StaticResource Stroke}"/>
            <Setter Property="BorderThickness"   Value="1"/>
            <Setter Property="Background"        Value="{StaticResource Bg0}"/>
            <Setter Property="FontSize"          Value="12"/>
        </Style>
        <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush"   Value="{StaticResource Accent}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
        </Style>
        <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="{StaticResource TextMuted}"/>
        </Style>

        <Style Selector="ComboBox">
            <Setter Property="CornerRadius"    Value="2"/>
            <Setter Property="Foreground"      Value="{StaticResource TextSecondary}"/>
            <Setter Property="Background"      Value="{StaticResource Bg0}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource Stroke}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="6,1"/>
            <Setter Property="FontSize"        Value="12"/>
        </Style>
        <Style Selector="ComboBox:pointerover">
            <Setter Property="BorderBrush" Value="{StaticResource TextMuted}"/>
        </Style>
        <Style Selector="ComboBox:focus">
            <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
        </Style>
        <Style Selector="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding"    Value="8,4"/>
            <Setter Property="FontSize"   Value="12"/>
        </Style>
        <Style Selector="ComboBoxItem:selected">
            <Setter Property="Background" Value="{StaticResource AccentSoft}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        </Style>
        <Style Selector="ComboBoxItem:pointerover">
            <Setter Property="Background" Value="{StaticResource Bg2}"/>
        </Style>

        <!-- ── Menu / MenuItem ────────────────────────────────────────────── -->
        <Style Selector="Menu">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
        </Style>
        <Style Selector="MenuItem">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding"    Value="8,4"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="CornerRadius" Value="2"/>
        </Style>
        <Style Selector="MenuItem:selected, MenuItem:pointerover">
            <Setter Property="Background" Value="{StaticResource Bg2}"/>
        </Style>

        <!-- ── Horizontal slider — chunky scrub bar ──────────────────────── -->
        <Style Selector="Slider:horizontal">
            <Setter Property="Background" Value="{StaticResource SliderTrack}"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="MaxHeight" Value="28"/>
            <Setter Property="Cursor" Value="SizeWestEast"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            Height="28" ClipToBounds="True">
                        <Track Name="PART_Track" Orientation="Horizontal"
                               Minimum="{TemplateBinding Minimum}"
                               Maximum="{TemplateBinding Maximum}"
                               Value="{TemplateBinding Value, Mode=TwoWay}">
                            <Track.DecreaseButton>
                                <RepeatButton Name="PART_DecreaseButton" Focusable="False">
                                    <RepeatButton.Template>
                                        <ControlTemplate>
                                            <Border Name="Fill" Background="{StaticResource SliderFill}"/>
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.DecreaseButton>
                            <Track.Thumb>
                                <Thumb Width="12" Cursor="SizeWestEast">
                                    <Thumb.Template>
                                        <ControlTemplate>
                                            <Border Width="12" Height="18" CornerRadius="3"
                                                    Background="{StaticResource SliderThumbLine}"
                                                    VerticalAlignment="Center"/>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                            <Track.IncreaseButton>
                                <RepeatButton Name="PART_IncreaseButton" Focusable="False">
                                    <RepeatButton.Template>
                                        <ControlTemplate>
                                            <Border Background="Transparent"/>
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.IncreaseButton>
                        </Track>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Slider:horizontal:pointerover /template/ RepeatButton#PART_DecreaseButton /template/ Border#Fill">
            <Setter Property="Background" Value="{StaticResource SliderFillHover}"/>
        </Style>
        <Style Selector="Slider:horizontal:pressed /template/ RepeatButton#PART_DecreaseButton /template/ Border#Fill">
            <Setter Property="Background" Value="{StaticResource SliderFillActive}"/>
        </Style>

        <!-- ── ScrollBar ───────────────────────────────────────────────── -->
        <Style Selector="ScrollBar">
            <Setter Property="Opacity" Value="0.4"/>
        </Style>

        <!-- ── ListBox / ListBoxItem ───────────────────────────────────── -->
        <Style Selector="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding"    Value="4,2"/>
            <Setter Property="CornerRadius" Value="2"/>
        </Style>
        <Style Selector="ListBoxItem:selected">
            <Setter Property="Background" Value="{StaticResource AccentSoft}"/>
        </Style>
        <Style Selector="ListBoxItem:pointerover">
            <Setter Property="Background" Value="{StaticResource Bg2}"/>
        </Style>

        <!-- ── Section header label ────────────────────────────────────── -->
        <!-- Usage: <TextBlock Classes="section-header" Text="COLOR"/> -->
        <Style Selector="TextBlock.section-header">
            <Setter Property="FontSize"     Value="10"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Foreground"   Value="{StaticResource TextMuted}"/>
            <Setter Property="LetterSpacing" Value="1.5"/>
            <Setter Property="Margin"       Value="0,0,0,5"/>
        </Style>

        <!-- ── Panel separator rule ────────────────────────────────────── -->
        <!-- Usage: <Separator/> or <Border Classes="rule"/> -->
        <Style Selector="Separator">
            <Setter Property="Background" Value="{StaticResource Stroke}"/>
            <Setter Property="Height"     Value="1"/>
            <Setter Property="Margin"     Value="0,6"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
        <Style Selector="Border.rule">
            <Setter Property="Background" Value="{StaticResource Stroke}"/>
            <Setter Property="Height"     Value="1"/>
            <Setter Property="Margin"     Value="0,6"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>

    </Application.Styles>
</Application>
