<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Floss.App.App"
             RequestedThemeVariant="Dark">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="/Styles/Theme.axaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />

        <Style Selector="Window">
            <Setter Property="FontFamily" Value="Inter, Segoe UI, Noto Sans, Ubuntu, Cantarell, Arial"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Background" Value="{StaticResource Bg0}"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
        </Style>

        <Style Selector="Button">
            <Setter Property="Background"    Value="Transparent"/>
            <Setter Property="BorderBrush"   Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius"  Value="2"/>
            <Setter Property="Padding"       Value="7,3"/>
            <Setter Property="Cursor"        Value="Hand"/>
            <Setter Property="Foreground"    Value="{StaticResource TextSecondary}"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            ClipToBounds="True">
                        <Panel>
                            <Border Name="Overlay" IsHitTestVisible="False"
                                    Background="Transparent"
                                    CornerRadius="{TemplateBinding CornerRadius}"/>
                            <ContentPresenter Padding="{TemplateBinding Padding}"
                                              HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              Foreground="{TemplateBinding Foreground}"/>
                        </Panel>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Button:pointerover /template/ Border#Overlay">
            <Setter Property="Background" Value="#14ffffff"/>
        </Style>
        <Style Selector="Button:pressed /template/ Border#Overlay">
            <Setter Property="Background" Value="#24ffffff"/>
        </Style>
        <Style Selector="Button:disabled">
            <Setter Property="Opacity" Value="0.35"/>
        </Style>

        <!-- ── ToggleButton ───────────────────────────────────────────────── -->
        <Style Selector="ToggleButton">
            <Setter Property="Background"    Value="Transparent"/>
            <Setter Property="BorderBrush"   Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius"  Value="2"/>
            <Setter Property="Padding"       Value="7,3"/>
            <Setter Property="Cursor"        Value="Hand"/>
            <Setter Property="Foreground"    Value="{StaticResource TextSecondary}"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            ClipToBounds="True">
                        <Panel>
                            <Border Name="Overlay" IsHitTestVisible="False"
                                    Background="Transparent"
                                    CornerRadius="{TemplateBinding CornerRadius}"/>
                            <ContentPresenter Padding="{TemplateBinding Padding}"
                                              HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              Foreground="{TemplateBinding Foreground}"/>
                        </Panel>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="ToggleButton:pointerover /template/ Border#Overlay">
            <Setter Property="Background" Value="#14ffffff"/>
        </Style>
        <Style Selector="ToggleButton:pressed /template/ Border#Overlay">
            <Setter Property="Background" Value="#24ffffff"/>
        </Style>

        <Style Selector="TextBox">
            <Setter Property="CornerRadius"     Value="2"/>
            <Setter Property="Foreground"       Value="{StaticResource TextPrimary}"/>
            <Setter Property="CaretBrush"       Value="{StaticResource TextPrimary}"/>
            <Setter Property="SelectionBrush"    Value="{StaticResource Accent}"/>
            <Setter Property="SelectionForegroundBrush" Value="#ffffff"/>
            <Setter Property="BorderBrush"       Value="{StaticResource Stroke}"/>
            <Setter Property="BorderThickness"   Value="1"/>
            <Setter Property="Background"        Value="{StaticResource Bg0}"/>
            <Setter Property="FontSize"          Value="12"/>
        </Style>
        <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush"   Value="{StaticResource Accent}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
        </Style>
        <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="{StaticResource TextMuted}"/>
        </Style>

        <Style Selector="ComboBox">
            <Setter Property="CornerRadius"    Value="2"/>
            <Setter Property="Foreground"      Value="{StaticResource TextSecondary}"/>
            <Setter Property="Background"      Value="{StaticResource Bg0}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource Stroke}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="6,1"/>
            <Setter Property="FontSize"        Value="12"/>
        </Style>
        <Style Selector="ComboBox:pointerover">
            <Setter Property="BorderBrush" Value="{StaticResource TextMuted}"/>
        </Style>
        <Style Selector="ComboBox:focus">
            <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
        </Style>
        <Style Selector="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding"    Value="8,4"/>
            <Setter Property="FontSize"   Value="12"/>
        </Style>
        <Style Selector="ComboBoxItem:selected">
            <Setter Property="Background" Value="{StaticResource AccentSoft}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        </Style>
        <Style Selector="ComboBoxItem:pointerover">
            <Setter Property="Background" Value="{StaticResource Bg2}"/>
        </Style>

        <!-- ── Menu / MenuItem ────────────────────────────────────────────── -->
        <Style Selector="Menu">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
        </Style>
        <Style Selector="MenuItem">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding"    Value="8,4"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="CornerRadius" Value="2"/>
        </Style>
        <Style Selector="MenuItem:selected, MenuItem:pointerover">
            <Setter Property="Background" Value="{StaticResource Bg2}"/>
        </Style>

        <!-- ── Horizontal slider — modern rounded track ─────────────────── -->
        <Style Selector="Slider:horizontal">
            <Setter Property="Background" Value="{StaticResource SliderTrack}"/>
            <Setter Property="MinHeight" Value="18"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Grid MinHeight="20" VerticalAlignment="Center">
                        <Border VerticalAlignment="Center" Height="4" CornerRadius="2"
                                Background="{TemplateBinding Background}"
                                IsHitTestVisible="False"/>
                        <Track Name="PART_Track" Orientation="Horizontal"
                               Minimum="{TemplateBinding Minimum}"
                               Maximum="{TemplateBinding Maximum}"
                               Value="{TemplateBinding Value, Mode=TwoWay}">
                            <Track.DecreaseButton>
                                <RepeatButton Name="PART_DecreaseButton" Focusable="False" Cursor="Hand">
                                    <RepeatButton.Template>
                                        <ControlTemplate>
                                            <Border Name="Fill" Height="4" VerticalAlignment="Center"
                                                    CornerRadius="2,0,0,2" Background="{StaticResource SliderFill}"/>
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.DecreaseButton>
                            <Track.Thumb>
                                <Thumb Cursor="Hand" Width="14" Height="14">
                                    <Thumb.Template>
                                        <ControlTemplate>
                                            <Grid Width="14" Height="14">
                                                <Ellipse Width="12" Height="12"
                                                         Fill="{StaticResource SliderThumb}"
                                                         Stroke="{StaticResource Bg1}"
                                                         StrokeThickness="1"/>
                                            </Grid>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                            <Track.IncreaseButton>
                                <RepeatButton Name="PART_IncreaseButton" Focusable="False" Cursor="Hand">
                                    <RepeatButton.Template>
                                        <ControlTemplate>
                                            <Border Height="8" VerticalAlignment="Center"
                                                    Background="Transparent"/>
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.IncreaseButton>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Slider:horizontal:pointerover /template/ RepeatButton#PART_DecreaseButton /template/ Border#Fill">
            <Setter Property="Background" Value="#4d82ec"/>
        </Style>
        <Style Selector="Slider:horizontal:pressed /template/ RepeatButton#PART_DecreaseButton /template/ Border#Fill">
            <Setter Property="Background" Value="#5a90f5"/>
        </Style>
        <Style Selector="Slider:horizontal:pointerover /template/ Thumb /template/ Ellipse">
            <Setter Property="Fill" Value="#90b4f8"/>
        </Style>
        <Style Selector="Slider:horizontal:pressed /template/ Thumb /template/ Ellipse">
            <Setter Property="Fill" Value="#a8c4fa"/>
        </Style>

        <!-- ── ScrollBar ───────────────────────────────────────────────── -->
        <Style Selector="ScrollBar">
            <Setter Property="Opacity" Value="0.4"/>
        </Style>

        <!-- ── ListBox / ListBoxItem ───────────────────────────────────── -->
        <Style Selector="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding"    Value="4,2"/>
            <Setter Property="CornerRadius" Value="2"/>
        </Style>
        <Style Selector="ListBoxItem:selected">
            <Setter Property="Background" Value="{StaticResource AccentSoft}"/>
        </Style>
        <Style Selector="ListBoxItem:pointerover">
            <Setter Property="Background" Value="{StaticResource Bg2}"/>
        </Style>

    </Application.Styles>
</Application>
