<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- ═════════════════════════════════════════════════════════════════════
         Shared color palette — single source of truth for XAML styles.
         Mirror of AppColors.cs; keep in sync.
    ═════════════════════════════════════════════════════════════════════ -->
    <!-- Backgrounds -->
    <Color x:Key="Bg0">#131313</Color>
    <Color x:Key="Bg1">#1a1a1a</Color>
    <Color x:Key="Bg2">#212121</Color>
    <Color x:Key="Bg3">#292929</Color>
    <Color x:Key="BgSidebar">#171717</Color>

    <!-- Borders -->
    <Color x:Key="Stroke">#2e2e2e</Color>

    <!-- Text -->
    <Color x:Key="TextPrimary">#e0e0e0</Color>
    <Color x:Key="TextSecondary">#aaaaaa</Color>
    <Color x:Key="TextMuted">#787878</Color>

    <!-- Accents -->
    <Color x:Key="Accent">#4f78b8</Color>
    <Color x:Key="AccentSoft">#263850</Color>
    <Color x:Key="AccentWarm">#d28a45</Color>
    <Color x:Key="AccentWarmSoft">#3d2b1e</Color>

    <!-- Semantic -->
    <Color x:Key="Success">#3fb950</Color>
    <Color x:Key="Warning">#d29922</Color>
    <Color x:Key="Danger">#da3633</Color>

    <!-- Slider -->
    <Color x:Key="SliderTrack">#0d0d0d</Color>
    <Color x:Key="SliderFill">#3a6bc9</Color>
    <Color x:Key="SliderFillHover">#4a7de0</Color>
    <Color x:Key="SliderFillActive">#5a8ef5</Color>
    <Color x:Key="SliderThumb">#88a6d4</Color>
    <Color x:Key="SliderThumbLine">#7aa4ec</Color>

    <!-- Corner Radii -->
    <CornerRadius x:Key="SmRadius">4</CornerRadius>
    <CornerRadius x:Key="ControlRadius">6</CornerRadius>
    <CornerRadius x:Key="CardRadius">8</CornerRadius>
    <CornerRadius x:Key="FullRadius">999</CornerRadius>

    <!-- ── Brushes (convenience) ────────────────────────────────────────── -->
    <SolidColorBrush x:Key="Bg0Brush"            Color="{StaticResource Bg0}"/>
    <SolidColorBrush x:Key="Bg1Brush"            Color="{StaticResource Bg1}"/>
    <SolidColorBrush x:Key="Bg2Brush"            Color="{StaticResource Bg2}"/>
    <SolidColorBrush x:Key="Bg3Brush"            Color="{StaticResource Bg3}"/>
    <SolidColorBrush x:Key="StrokeBrush"         Color="{StaticResource Stroke}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush"    Color="{StaticResource TextPrimary}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush"  Color="{StaticResource TextSecondary}"/>
    <SolidColorBrush x:Key="TextMutedBrush"      Color="{StaticResource TextMuted}"/>
    <SolidColorBrush x:Key="AccentBrush"         Color="{StaticResource Accent}"/>
    <SolidColorBrush x:Key="AccentSoftBrush"     Color="{StaticResource AccentSoft}"/>
    <SolidColorBrush x:Key="AccentWarmBrush"     Color="{StaticResource AccentWarm}"/>
    <SolidColorBrush x:Key="AccentWarmSoftBrush" Color="{StaticResource AccentWarmSoft}"/>
    <SolidColorBrush x:Key="DangerBrush"         Color="{StaticResource Danger}"/>
    <SolidColorBrush x:Key="SuccessBrush"        Color="{StaticResource Success}"/>
    <SolidColorBrush x:Key="WarningBrush"        Color="{StaticResource Warning}"/>
</ResourceDictionary>
