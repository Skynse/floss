<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:canvas="clr-namespace:Floss.App.Canvas"
        x:Class="Floss.App.MainWindow"
        Width="1440"
        Height="920"
        MinWidth="1024"
        MinHeight="680"
        Background="#151719"
        Title="Floss">
  <Grid RowDefinitions="42,*,24">
    <Border Grid.Row="0" Background="#202226" Padding="16,0">
      <Grid ColumnDefinitions="Auto,18,Auto,*,Auto" VerticalAlignment="Center">
        <TextBlock Text="Floss" Foreground="#d8dbe0" FontWeight="Bold" FontSize="15"/>
        <TextBlock x:Name="ToolStatusText" Grid.Column="2" Foreground="#8b9099" FontSize="12"/>
        <TextBlock x:Name="CanvasStatusText" Grid.Column="4" Foreground="#8b9099" FontSize="12"/>
      </Grid>
    </Border>

    <Grid Grid.Row="1" ColumnDefinitions="54,*,360">
      <Border Grid.Column="0" Background="#202226">
        <StackPanel Margin="6,10" Spacing="8">
          <Button x:Name="BrushToolButton" Content="B" Width="42" Height="36"/>
          <Button x:Name="EraserToolButton" Content="E" Width="42" Height="36"/>
          <Button x:Name="ClearButton" Content="C" Width="42" Height="36"/>
          <Border Height="1" Background="#32363e" Margin="0,8"/>
          <Button x:Name="UndoButton" Content="↶" Width="42" Height="36"/>
          <Button x:Name="RedoButton" Content="↷" Width="42" Height="36"/>
        </StackPanel>
      </Border>

      <Border x:Name="WorkspaceViewport"
              Grid.Column="1"
              Background="#111316"
              ClipToBounds="True"
              PointerPressed="Workspace_OnPointerPressed"
              PointerMoved="Workspace_OnPointerMoved"
              PointerReleased="Workspace_OnPointerReleased"
              PointerWheelChanged="Workspace_OnPointerWheelChanged">
          <Grid x:Name="Workspace"
                Width="1800"
                Height="1600"
                Background="#111316"
                RenderTransformOrigin="0.5,0.5">
            <Grid.RenderTransform>
              <TransformGroup>
                <ScaleTransform ScaleX="1" ScaleY="1"/>
                <TranslateTransform X="0" Y="0"/>
              </TransformGroup>
            </Grid.RenderTransform>
            <Border x:Name="CanvasFrame"
                    Width="900"
                    Height="900"
                    Background="#f7f4ed"
                    BorderBrush="#2a2d33"
                    BorderThickness="1"
                    BoxShadow="0 12 28 0 #66000000"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
              <canvas:DrawingCanvas x:Name="DrawingCanvas"/>
            </Border>
          </Grid>
      </Border>

      <Border Grid.Column="2" Background="#202226">
        <ScrollViewer>
          <StackPanel Margin="14" Spacing="14">
            <Border Background="#17191d" BorderBrush="#31353d" BorderThickness="1" Padding="12" CornerRadius="6">
              <StackPanel Spacing="10">
                <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                  <TextBlock Text="Color" Foreground="#d8dbe0" FontWeight="Bold"/>
                  <Border x:Name="ColorWell"
                          Grid.Column="1"
                          Width="30"
                          Height="30"
                          CornerRadius="15"
                          BorderBrush="#707783"
                          BorderThickness="1"/>
                </Grid>
                <WrapPanel x:Name="SwatchPanel"/>
              </StackPanel>
            </Border>

            <Border Background="#17191d" BorderBrush="#31353d" BorderThickness="1" Padding="12" CornerRadius="6">
              <StackPanel Spacing="10">
                <TextBlock Text="Brush" Foreground="#d8dbe0" FontWeight="Bold"/>
                <StackPanel x:Name="PresetPanel" Spacing="8"/>
                <TextBlock Text="Size" Foreground="#a1a6b0" FontSize="12"/>
                <Slider x:Name="SizeSlider" Minimum="1" Maximum="128"/>
                <TextBlock Text="Opacity" Foreground="#a1a6b0" FontSize="12"/>
                <Slider x:Name="OpacitySlider" Minimum="0.05" Maximum="1"/>
                <TextBlock Text="Hardness" Foreground="#a1a6b0" FontSize="12"/>
                <Slider x:Name="HardnessSlider" Minimum="0" Maximum="1"/>
                <TextBlock Text="Spacing" Foreground="#a1a6b0" FontSize="12"/>
                <Slider x:Name="SpacingSlider" Minimum="0.02" Maximum="0.6"/>
              </StackPanel>
            </Border>

            <Border Background="#17191d" BorderBrush="#31353d" BorderThickness="1" Padding="12" CornerRadius="6">
              <StackPanel Spacing="10">
                <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto,Auto" VerticalAlignment="Center">
                  <TextBlock Text="Layers" Foreground="#d8dbe0" FontWeight="Bold"/>
                  <Button x:Name="AddLayerButton" Grid.Column="1" Content="+" Width="30" Height="28"/>
                  <Button x:Name="DuplicateLayerButton" Grid.Column="2" Content="⧉" Width="30" Height="28"/>
                  <Button x:Name="DeleteLayerButton" Grid.Column="3" Content="-" Width="30" Height="28"/>
                  <Button x:Name="MoveLayerUpButton" Grid.Column="4" Content="↑" Width="30" Height="28"/>
                  <Button x:Name="MoveLayerDownButton" Grid.Column="5" Content="↓" Width="30" Height="28"/>
                </Grid>
                <Grid ColumnDefinitions="Auto,*" VerticalAlignment="Center">
                  <TextBlock Text="Opacity" Foreground="#a1a6b0" FontSize="12" VerticalAlignment="Center"/>
                  <Slider x:Name="LayerOpacitySlider" Grid.Column="1" Minimum="0" Maximum="1" Margin="10,0,0,0"/>
                </Grid>
                <StackPanel x:Name="LayerPanel" Spacing="6"/>
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>
      </Border>
    </Grid>

    <Border Grid.Row="2" Background="#151719" Padding="12,0">
      <TextBlock x:Name="FooterStatusText" Foreground="#8b9099" FontSize="11" VerticalAlignment="Center"/>
    </Border>
  </Grid>
</Window>
