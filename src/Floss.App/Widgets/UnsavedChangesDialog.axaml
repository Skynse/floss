<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Floss.App.UnsavedChangesDialog" Title="Unsaved Changes"
        Width="380" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="{StaticResource Bg1}"
        Foreground="{StaticResource TextPrimary}">

    <StackPanel Margin="20" Spacing="20">
        <TextBlock x:Name="MessageText"
                   Text="Save changes to the current document before closing?"
                   FontSize="14"
                   TextWrapping="Wrap"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button Content="Cancel"    Click="OnCancelClick"   Classes="outline" Width="80"  HorizontalContentAlignment="Center"/>
            <Button Content="Don't Save" Click="OnDontSaveClick" Classes="outline" Width="96" HorizontalContentAlignment="Center"/>
            <Button Content="Save"      Click="OnSaveClick"      Classes="primary" Width="80"  HorizontalContentAlignment="Center"/>
        </StackPanel>
    </StackPanel>
</Window>
