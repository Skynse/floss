# Copy to packaging/release/.env.release (gitignored) and fill in once.
# Then: ./packaging/release/setup-gitlab-ci.sh
#   or: glab variable set … (see notes/release-automation.md)

# GitLab personal access token (api scope) — only needed for setup-gitlab-ci.sh
# https://gitlab.com/-/user_settings/personal_access_tokens
GITLAB_TOKEN=glpat-...

# Gumroad — https://app.gumroad.com/settings/advanced#application-form
# Create an application / access token with edit_products scope.
GUMROAD_ACCESS_TOKEN=
# API id from edit URL (not the public slug): https://gumroad.com/products/dqmpcx/edit
GUMROAD_PRODUCT_ID=dqmpcx
# Public product page — custom permalink slug is "floss"
GUMROAD_PRODUCT_URL=https://popshuvit.gumroad.com/l/floss

# GITLAB_PROJECT=Skynse/floss
