# Copy to packaging/release/.env.release (gitignored) and fill in once.
# Then: ./packaging/release/setup-gitlab-ci.sh

# GitLab personal access token (api scope) — https://gitlab.com/-/user_settings/personal_access_tokens
GITLAB_TOKEN=glpat-...

# Cloudflare R2 (S3 API token)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ACCOUNT_ID=
R2_BUCKET=floss-cdn
CDN_PUBLIC_URL=https://cdn.flosspaint.com

# Optional overrides
# R2_PREFIX=downloads
# R2_ENDPOINT=
# GITLAB_PROJECT=Skynse/floss
