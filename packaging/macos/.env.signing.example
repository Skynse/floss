# Copy to .env.signing (gitignored) on your Mac, then: source packaging/macos/.env.signing
#
# 1. Apple Developer Program membership ($99/yr)
# 2. Create "Developer ID Application" cert in developer.apple.com → Certificates
#    (Xcode → Settings → Accounts → Manage Certificates also works)
# 3. App-specific password: appleid.apple.com → Sign-In and Security
# 4. One-time keychain profile (recommended):
#      xcrun notarytool store-credentials "Floss-Notary" \
#        --apple-id "you@example.com" \
#        --team-id "XXXXXXXXXX" \
#        --password "xxxx-xxxx-xxxx-xxxx"

export APPLE_SIGNING_IDENTITY="Developer ID Application: Your Name (XXXXXXXXXX)"

# Option A — keychain profile (preferred)
export APPLE_NOTARY_KEYCHAIN_PROFILE="Floss-Notary"

# Option B — inline (CI / one-off; do not commit)
# export APPLE_ID="you@example.com"
# export APPLE_APP_PASSWORD="xxxx-xxxx-xxxx-xxxx"
# export APPLE_TEAM_ID="XXXXXXXXXX"

# Set to 1 to codesign only (skip notarization + staple)
# export SKIP_NOTARIZE=1
